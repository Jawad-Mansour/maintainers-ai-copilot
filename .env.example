# Bootstrap only — copy to .env and fill in the values marked REQUIRED.
# The app reads ALL secrets from Vault at startup — never from this file directly.

# Vault (dev mode — leave as-is for local docker-compose)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# REQUIRED — seeded into Vault by vault-init on first boot.
# The app always reads this from Vault, never from .env.
OPENAI_API_KEY=sk-proj-replace-with-your-key

# Optional — if you have a real Langfuse cloud project, set these
# to override the self-hosted Langfuse dev instance in docker-compose.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Service ports exposed on the host (change only to avoid conflicts)
POSTGRES_PORT=5433
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=8000
CHATBOT_PORT=8501
WIDGET_PORT=5173
LANGFUSE_PORT=3000
MODELSERVER_PORT=8001
