# Bootstrap only — these values tell the app WHERE Vault is.
# All actual secrets (DB password, OpenAI key, JWT key, MinIO creds, Langfuse keys)
# are fetched from Vault at startup. Do NOT add secrets here.

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Service ports (exposed on host for local dev)
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=8000
CHATBOT_PORT=8501
WIDGET_PORT=5173
LANGFUSE_PORT=3000
MODELSERVER_PORT=8001
